---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import Icon from '../components/Icon.astro';
import JsonLd from '../components/JsonLd.astro';
import { PUB_TOPICS } from '../content.config';
import { getPublications, publicationCounts } from '../lib/content';
import { groupByYear, isPI, primaryLink } from '../lib/publications';
import { fullName } from '../lib/profile';

const pubs = await getPublications();
const counts = publicationCounts(pubs);
const grouped = groupByYear(pubs);

// Only show topic filters that actually occur, in the controlled order.
const usedTopics = PUB_TOPICS.filter((t) => pubs.some((p) => p.topics.includes(t)));

const TYPES = [
  { value: 'journal', label: 'Journal' },
  { value: 'conference', label: 'Conference' },
  { value: 'book-chapter', label: 'Book chapter' },
] as const;

// Build a single lowercase search string per pub for the client filter.
const searchString = (p: (typeof pubs)[number]) =>
  [p.title, p.authors.join(' '), p.venue, String(p.year)].join(' ').toLowerCase();

// JSON-LD: each publication as a ScholarlyArticle.
const articlesLd = pubs.map((p) => ({
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: p.title,
  author: p.authors.map((name) => ({
    '@type': 'Person',
    name,
    ...(isPI(name) ? { sameAs: `https://orcid.org/0000-0002-7651-5639` } : {}),
  })),
  datePublished: String(p.year),
  isPartOf: { '@type': 'Periodical', name: p.venue },
  ...(p.doi ? { sameAs: `https://doi.org/${p.doi}` } : {}),
  ...(primaryLink(p) ? { url: primaryLink(p) } : {}),
}));
---

<BaseLayout
  pageTitle="Publications"
  description={`Publications by ${fullName}: ${counts.journal} journal articles and ${counts.chaptersAndProceedings} chapters & proceedings across mathematical epidemiology, ecology, HIV dynamics, nonlinear dynamics and coding theory. Searchable and filterable.`}
>
  <JsonLd slot="head" data={articlesLd} />

  <div class="container-page page-intro">
    <p class="eyebrow">Publications</p>
    <h1>Publications</h1>
    <p class="intro-lead">
      {counts.total} works in total - <strong>{counts.journal}</strong> journal articles and
      <strong> {counts.chaptersAndProceedings}</strong> chapters &amp; proceedings. Search by title,
      author or venue, or filter by topic and type. DOIs link to the published version; every entry
      offers a one-click BibTeX copy.
    </p>
  </div>

  <!-- ===== Prominent search bar (top) ===== -->
  <div class="container-page pubs-search">
    <div class="search-box">
      <label for="pub-search" class="sr-only">Search publications</label>
      <Icon name="search" size={20} class="search-icon" />
      <input
        type="search"
        id="pub-search"
        placeholder="Search 67 publications by title, author or venue…"
        autocomplete="off"
      />
    </div>
  </div>

  <div class="container-page pubs-layout">
    <!-- ===== Filter panel ===== -->
    <aside class="filter-panel" id="filters">
      <fieldset class="filter-group">
        <legend>Type</legend>
        <div class="chip-row" role="group" aria-label="Filter by type">
          {
            TYPES.map((t) => (
              <button class="chip js-type" data-type={t.value} aria-pressed="false" type="button">
                {t.label}
              </button>
            ))
          }
        </div>
      </fieldset>

      <fieldset class="filter-group">
        <legend>Topic</legend>
        <div class="chip-row" role="group" aria-label="Filter by topic">
          {
            usedTopics.map((t) => (
              <button class="chip js-topic" data-topic={t} aria-pressed="false" type="button">
                {t}
              </button>
            ))
          }
        </div>
      </fieldset>

      <button class="clear-btn js-clear" type="button" hidden>
        <Icon name="close" size={15} /> Clear all filters
      </button>

      <nav class="year-jump" aria-label="Jump to year">
        <span class="year-jump-label">Years</span>
        <ul>
          {grouped.map((g) => <li><a href={`#year-${g.year}`}>{g.year}</a></li>)}
        </ul>
      </nav>
    </aside>

    <!-- ===== Results ===== -->
    <div class="results">
      <p class="result-count" id="result-count" aria-live="polite" role="status">
        Showing all {counts.total} publications
      </p>

      <p class="no-results" id="no-results" hidden>
        No publications match your search. <button class="link-btn js-clear" type="button">Clear filters</button>
      </p>

      {
        grouped.map((g) => (
          <section class="year-group" id={`year-${g.year}`} data-year-group={g.year}>
            <h2 class="year-heading">
              <span>{g.year}</span>
              <span class="year-count" data-year-count>{g.items.length}</span>
            </h2>
            <ul class="pub-list">
              {g.items.map((pub) => (
                <li
                  class="pub-row"
                  data-pub
                  data-search={searchString(pub)}
                  data-type={pub.type}
                  data-topics={pub.topics.join('|')}
                >
                  <PublicationItem pub={pub} showYear={false} />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page-intro {
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: 1rem;
  }
  .page-intro h1 {
    font-size: var(--text-4xl);
    color: var(--color-primary);
    margin-top: 0.5rem;
  }
  .intro-lead {
    margin-top: 1rem;
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  /* Prominent search bar at the top */
  .pubs-search {
    padding-top: 0.5rem;
  }
  .pubs-search .search-box input {
    font-size: 1.05rem;
    padding: 0.85rem 1rem 0.85rem 2.75rem;
    box-shadow: var(--shadow-card);
  }
  .pubs-search .search-box :global(.search-icon) {
    left: 1rem;
  }

  .pubs-layout {
    display: grid;
    grid-template-columns: 17rem minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding-block: 1.5rem 1rem;
    align-items: start;
  }

  .filter-panel {
    position: sticky;
    top: calc(var(--nav-h) + 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-box :global(.search-icon) {
    position: absolute;
    left: 0.75rem;
    color: var(--color-ink-faint);
    pointer-events: none;
  }
  .search-box input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.75rem 0.6rem 2.4rem;
  }
  .search-box input:focus {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
    border-color: var(--color-focus);
  }

  .filter-group {
    border: 0;
    margin: 0;
    padding: 0;
  }
  .filter-group legend {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-ink-faint);
    margin-bottom: 0.7rem;
    padding: 0;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .chip {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    background: var(--color-surface);
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: all 0.13s ease;
  }
  .chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .chip[aria-pressed='true'] {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-paper);
  }

  .clear-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0;
  }
  .clear-btn:hover {
    color: var(--color-accent);
  }

  .year-jump {
    border-top: 1px solid var(--color-line);
    padding-top: 1.25rem;
  }
  .year-jump-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-ink-faint);
  }
  .year-jump ul {
    list-style: none;
    margin: 0.7rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .year-jump a {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-link);
    text-decoration: none;
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius-sm);
  }
  .year-jump a:hover {
    background: var(--color-primary-soft);
  }

  .result-count {
    font-size: 0.9rem;
    color: var(--color-ink-faint);
    margin-bottom: 0.5rem;
  }
  .no-results {
    padding: 2rem 0;
    color: var(--color-ink-soft);
  }
  .link-btn {
    background: none;
    border: 0;
    color: var(--color-link);
    cursor: pointer;
    font-size: inherit;
    text-decoration: underline;
    padding: 0;
  }

  .year-group {
    scroll-margin-top: calc(var(--nav-h) + 1rem);
    margin-bottom: 2rem;
  }
  .year-heading {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--text-xl);
    color: var(--color-primary);
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-line);
    position: sticky;
    top: var(--nav-h);
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    backdrop-filter: blur(4px);
    z-index: 1;
  }
  .year-count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-ink-faint);
    background: var(--color-surface-soft);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }
  .pub-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 56rem) {
    .pubs-layout {
      grid-template-columns: 1fr;
    }
    .filter-panel {
      position: static;
    }
    .year-jump {
      display: none;
    }
  }
</style>

<script>
  // ---- Publications filter + search (progressive enhancement) ----
  // The full grouped list is server-rendered; this only shows/hides items.
  const root = document.querySelector('.pubs-layout');
  if (root) {
    // The search box now lives in a top bar outside .pubs-layout.
    const search = document.querySelector<HTMLInputElement>('#pub-search');
    const typeChips = [...root.querySelectorAll<HTMLButtonElement>('.js-type')];
    const topicChips = [...root.querySelectorAll<HTMLButtonElement>('.js-topic')];
    const clearBtns = [...root.querySelectorAll<HTMLButtonElement>('.js-clear')];
    const rows = [...root.querySelectorAll<HTMLElement>('[data-pub]')];
    const groups = [...root.querySelectorAll<HTMLElement>('[data-year-group]')];
    const countEl = root.querySelector('#result-count');
    const noResults = root.querySelector<HTMLElement>('#no-results');
    const total = rows.length;

    const state = { q: '', types: new Set<string>(), topics: new Set<string>() };

    function toggle(set: Set<string>, value: string, btn: HTMLButtonElement) {
      if (set.has(value)) {
        set.delete(value);
        btn.setAttribute('aria-pressed', 'false');
      } else {
        set.add(value);
        btn.setAttribute('aria-pressed', 'true');
      }
      apply();
    }

    function apply() {
      const q = state.q.trim().toLowerCase();
      const terms = q ? q.split(/\s+/) : [];
      let visible = 0;

      for (const row of rows) {
        const hay = row.dataset.search ?? '';
        const type = row.dataset.type ?? '';
        const topics = (row.dataset.topics ?? '').split('|');
        const matchSearch = terms.every((t) => hay.includes(t));
        const matchType = state.types.size === 0 || state.types.has(type);
        const matchTopic =
          state.topics.size === 0 || topics.some((t) => state.topics.has(t));
        const show = matchSearch && matchType && matchTopic;
        row.hidden = !show;
        if (show) visible++;
      }

      // Update per-year group visibility + counts.
      for (const group of groups) {
        const groupRows = [...group.querySelectorAll<HTMLElement>('[data-pub]')];
        const shown = groupRows.filter((r) => !r.hidden).length;
        group.hidden = shown === 0;
        const countBadge = group.querySelector('[data-year-count]');
        if (countBadge) countBadge.textContent = String(shown);
      }

      const hasFilters = state.q !== '' || state.types.size > 0 || state.topics.size > 0;
      clearBtns.forEach((b) => (b.hidden = !hasFilters));
      if (noResults) noResults.hidden = visible !== 0;
      if (countEl) {
        countEl.textContent = hasFilters
          ? `Showing ${visible} of ${total} publications`
          : `Showing all ${total} publications`;
      }
    }

    function clearAll() {
      state.q = '';
      state.types.clear();
      state.topics.clear();
      if (search) search.value = '';
      [...typeChips, ...topicChips].forEach((c) => c.setAttribute('aria-pressed', 'false'));
      apply();
    }

    search?.addEventListener('input', () => {
      state.q = search.value;
      apply();
    });
    typeChips.forEach((c) =>
      c.addEventListener('click', () => toggle(state.types, c.dataset.type ?? '', c)),
    );
    topicChips.forEach((c) =>
      c.addEventListener('click', () => toggle(state.topics, c.dataset.topic ?? '', c)),
    );
    clearBtns.forEach((b) => b.addEventListener('click', clearAll));

    // Honor a deep link like ?topic=Tuberculosis or ?type=journal.
    const params = new URLSearchParams(window.location.search);
    const initialTopic = params.get('topic');
    const initialType = params.get('type');
    if (initialTopic) {
      const chip = topicChips.find((c) => c.dataset.topic === initialTopic);
      if (chip) toggle(state.topics, initialTopic, chip);
    }
    if (initialType) {
      const chip = typeChips.find((c) => c.dataset.type === initialType);
      if (chip) toggle(state.types, initialType, chip);
    }
  }
</script>
