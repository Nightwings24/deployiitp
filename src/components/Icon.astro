---
/**
 * Inline SVG icon set. Stroke-based, consistent line weight, uses currentColor.
 * Decorative by default (aria-hidden); pass a `title` to make it labelled.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  title?: string;
}
const { name, size = 20, class: className = '', title } = Astro.props;

// Each entry is the inner markup of a 24x24 viewBox icon.
const icons: Record<string, string> = {
  email: '<path d="M3 6.5h18v11H3z"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  phone:
    '<path d="M6.5 3.5h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 4.5 5.5a2 2 0 0 1 2-2Z"/>',
  location: '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  scholar: '<path d="M12 3 1.5 9 12 15l8.5-4.86V16h1.5V9z"/><path d="M5.5 12.2V16a6.5 4 0 0 0 13 0v-3.8"/>',
  orcid:
    '<circle cx="12" cy="12" r="9"/><path d="M9 8.5v7M9 6.6v.1M11.7 8.5v7h2.1a3.5 3.5 0 0 0 0-7Z"/>',
  researchgate: '<circle cx="12" cy="12" r="9"/><path d="M9.5 16V9h2.2a2 2 0 0 1 0 4H9.5m2.4 0 2.1 3"/>',
  linkedin:
    '<rect x="3.5" y="3.5" width="17" height="17" rx="2"/><path d="M8 10.5V16M8 7.6v.1M11.6 16v-5.5m0 1.5a2.4 2.4 0 0 1 4.4 1.4V16"/>',
  link: '<path d="M10 14a4 4 0 0 0 5.7 0l3-3A4 4 0 1 0 13 5.3l-1.5 1.5"/><path d="M14 10a4 4 0 0 0-5.7 0l-3 3A4 4 0 1 0 11 18.7l1.5-1.5"/>',
  external: '<path d="M14 4h6v6"/><path d="M20 4 10 14"/><path d="M19 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h5"/>',
  download: '<path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/>',
  'arrow-right': '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  'arrow-up-right': '<path d="M7 17 17 7"/><path d="M8 7h9v9"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  close: '<path d="m6 6 12 12M18 6 6 18"/>',
  copy: '<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h8"/>',
  check: '<path d="m5 12 5 5L20 6"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  filter: '<path d="M3 5h18l-7 8v6l-4-2v-4z"/>',
  // Research theme glyphs
  virus: '<circle cx="12" cy="12" r="5"/><path d="M12 3v3m0 12v3M3 12h3m12 0h3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1m0-12.8-2.1 2.1M7.7 16.3l-2.1 2.1"/>',
  leaf: '<path d="M5 19c0-8 5-13 14-13 0 9-5 14-13 14"/><path d="M5 19c3-5 6-7 10-8"/>',
  curve: '<path d="M3 20c4 0 4-14 8-14s4 11 10 5"/><path d="M3 20h18"/>',
  cell: '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/><path d="M12 4v2m0 12v2"/>',
  grid: '<rect x="4" y="4" width="6.5" height="6.5" rx="1"/><rect x="13.5" y="4" width="6.5" height="6.5" rx="1"/><rect x="4" y="13.5" width="6.5" height="6.5" rx="1"/><rect x="13.5" y="13.5" width="6.5" height="6.5" rx="1"/>',
  quote: '<path d="M9 7H5v5h4V7l-2 4M19 7h-4v5h4V7l-2 4"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M2 12h2m16 0h2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4m0-14.2-1.4 1.4M6.3 17.7l-1.4 1.4"/>',
  moon: '<path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"/>',
};

const markup = icons[name] ?? icons.link;
const labelled = Boolean(title);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon ${className}`}
  role={labelled ? 'img' : undefined}
  aria-hidden={labelled ? undefined : 'true'}
  aria-label={title}
  set:html={(labelled ? `<title>${title}</title>` : '') + markup}
/>

<style>
  .icon {
    display: inline-block;
    flex: none;
    vertical-align: middle;
  }
</style>
