---
import Icon from './Icon.astro';
import { navItems, isActive } from '../lib/site';
import { profile } from '../lib/profile';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="container-page nav-bar">
    <a class="brand" href="/">
      <span class="brand-name">{profile.shortName}</span>
    </a>

    <div class="nav-right">
      <!-- Desktop navigation -->
      <nav class="desktop-nav" aria-label="Primary">
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(currentPath, item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Theme toggle (light is default; choice persists in localStorage) -->
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch to dark theme">
        <Icon name="moon" size={20} class="icon-moon" />
        <Icon name="sun" size={20} class="icon-sun" />
      </button>

      <!-- Mobile navigation: native disclosure (works without JS), JS-enhanced -->
    <details class="mobile-nav" id="mobile-nav">
      <summary aria-label="Open menu">
        <Icon name="menu" size={24} class="icon-open" />
        <Icon name="close" size={24} class="icon-close" />
        <span class="sr-only">Menu</span>
      </summary>
      <nav class="mobile-panel" aria-label="Primary">
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(currentPath, item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-paper) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
  }

  .brand {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand:hover {
    color: var(--color-link);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 0;
    background: transparent;
    color: var(--color-ink-soft);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--color-primary);
    background: var(--color-surface-soft);
  }
  /* Show exactly one icon: moon in light (tap to go dark), sun in dark.
     :global() on the icon classes (they're on the <Icon> <svg> root) and on the
     html[data-theme] ancestor, which lives outside this component's scope.
     Kept in this scoped (unlayered) block so it beats Icon's own .icon rule. */
  .theme-toggle :global(.icon-sun) {
    display: none;
  }
  .theme-toggle :global(.icon-moon) {
    display: block;
  }
  :global(:root[data-theme='dark']) .theme-toggle :global(.icon-sun) {
    display: block;
  }
  :global(:root[data-theme='dark']) .theme-toggle :global(.icon-moon) {
    display: none;
  }

  .desktop-nav ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .desktop-nav a {
    display: inline-block;
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-md);
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .desktop-nav a:hover {
    color: var(--color-primary);
    background: var(--color-surface-soft);
  }
  .desktop-nav a[aria-current='page'] {
    color: var(--color-primary);
    background: var(--color-primary-soft);
  }

  /* Mobile disclosure */
  .mobile-nav {
    display: none;
    position: relative;
  }
  .mobile-nav summary {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    color: var(--color-primary);
    cursor: pointer;
    list-style: none;
  }
  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }
  .mobile-nav summary:hover {
    background: var(--color-surface-soft);
  }
  /* :global() because these classes live on the <Icon> component's <svg> root,
     which doesn't inherit this component's scoped style attribute. */
  .mobile-nav :global(.icon-close) {
    display: none;
  }
  .mobile-nav[open] :global(.icon-open) {
    display: none;
  }
  .mobile-nav[open] :global(.icon-close) {
    display: block;
  }

  .mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 13rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised);
    padding: 0.5rem;
  }
  .mobile-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .mobile-panel a {
    display: block;
    padding: 0.7rem 0.85rem;
    border-radius: var(--radius-md);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 500;
  }
  .mobile-panel a:hover {
    background: var(--color-surface-soft);
  }
  .mobile-panel a[aria-current='page'] {
    color: var(--color-primary);
    background: var(--color-primary-soft);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 60rem) {
    .desktop-nav {
      display: none;
    }
    .mobile-nav {
      display: block;
    }
  }
</style>

<script>
  // Progressive enhancement for the native <details> menu:
  // close on Escape, on link click, on outside click, and when widening to desktop.
  const details = document.getElementById('mobile-nav') as HTMLDetailsElement | null;
  if (details) {
    const summary = details.querySelector('summary');
    const close = () => {
      if (details.open) {
        details.open = false;
        summary?.setAttribute('aria-expanded', 'false');
      }
    };
    details.addEventListener('toggle', () => {
      summary?.setAttribute('aria-expanded', details.open ? 'true' : 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && details.open) {
        close();
        summary?.focus();
      }
    });
    details.querySelectorAll('.mobile-panel a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('click', (e) => {
      if (details.open && !details.contains(e.target as Node)) close();
    });
    const mq = window.matchMedia('(min-width: 60rem)');
    mq.addEventListener('change', (e) => {
      if (e.matches) close();
    });
  }

  // Theme toggle. The initial theme is applied in <head> before paint to avoid
  // a flash; here we just handle clicks and keep the button's label in sync.
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    const sync = () => {
      const isDark = document.documentElement.dataset.theme === 'dark';
      toggle.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
      toggle.setAttribute('aria-pressed', String(isDark));
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', isDark ? '#14161b' : '#1F3A5F');
    };
    sync();
    toggle.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      if (next === 'dark') document.documentElement.dataset.theme = 'dark';
      else delete document.documentElement.dataset.theme;
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* ignore storage errors (private mode) */
      }
      sync();
    });
  }
</script>
