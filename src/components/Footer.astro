---
import Icon from './Icon.astro';
import { navItems } from '../lib/site';
import { profile, fullName } from '../lib/profile';

// Build-time timestamp - shows the site is maintained.
const updated = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
const year = new Date().getFullYear();

const iconFor = (label: string, icon?: string) => icon ?? 'link';
---

<footer class="site-footer">
  <div class="container-page footer-grid">
    <div class="footer-about">
      <p class="footer-name">{fullName}</p>
      <p class="footer-meta">
        {profile.labName} · {profile.department}<br />
        {profile.institution}
      </p>
      <p class="footer-meta">{profile.addressLines.join(', ')}</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <h2>Explore</h2>
      <ul>
        {navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-connect">
      <h2>Connect</h2>
      <ul>
        <li>
          <a href={`mailto:${profile.email}`}>
            <Icon name="email" size={16} /> {profile.email}
          </a>
        </li>
        {
          profile.links
            .filter((l) => !l.url.startsWith('mailto:'))
            .map((l) => (
              <li>
                <a href={l.url} target="_blank" rel="noopener">
                  <Icon name={iconFor(l.label, l.icon)} size={16} /> {l.label}
                </a>
              </li>
            ))
        }
        {
          profile.cv && (
            <li>
              <a href={profile.cv}>
                <Icon name="download" size={16} /> Curriculum Vitae (PDF)
              </a>
            </li>
          )
        }
      </ul>
    </div>
  </div>

  <div class="container-page footer-bottom">
    <p>© {year} {fullName}. All rights reserved.</p>
    <p>Last updated {updated}.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-line);
    background: var(--color-surface-soft);
    padding-block: 3rem 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 2.5rem;
  }

  .footer-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .footer-meta {
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .footer-links h2,
  .footer-connect h2 {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
    margin-bottom: 0.85rem;
  }
  .footer-links ul,
  .footer-connect ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links a,
  .footer-connect a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-ink-soft);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .footer-links a:hover,
  .footer-connect a:hover {
    color: var(--color-link);
    text-decoration: underline;
  }
  .footer-connect :global(.icon) {
    color: var(--color-ink-faint);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    color: var(--color-ink-faint);
    font-size: 0.85rem;
  }
  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 48rem) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
