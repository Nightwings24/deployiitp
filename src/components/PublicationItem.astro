---
import Icon from './Icon.astro';
import Tag from './Tag.astro';
import { isPI, citationDetail, primaryLink, toBibTeX, type Publication } from '../lib/publications';

interface Props {
  pub: Publication;
  showYear?: boolean;
}
const { pub, showYear = true } = Astro.props;

const link = primaryLink(pub);
const detail = citationDetail(pub);
const bibtex = toBibTeX(pub);
const statusLabel = pub.status === 'accepted' ? 'Accepted' : pub.status === 'in-press' ? 'In press' : null;
const freeLink = pub.pdfUrl;
---

<article class="pub">
  <div class="pub-body">
    <h3 class="pub-title">
      {
        link ? (
          <a href={link} target="_blank" rel="noopener noreferrer">
            {pub.title}
          </a>
        ) : (
          pub.title
        )
      }
    </h3>

    <p class="pub-authors">
      {
        pub.authors.map((author, i) => (
          <>
            {isPI(author) ? <strong>{author}</strong> : author}
            {i < pub.authors.length - 1 ? ', ' : ''}
          </>
        ))
      }
    </p>

    <p class="pub-meta">
      <cite>{pub.venue}</cite>{showYear ? <> · {pub.year}</> : null}{detail ? `, ${detail}` : ''}
    </p>

    <div class="pub-tags">
      {statusLabel && <Tag variant="status">{statusLabel}</Tag>}
      {pub.topics.map((t) => <Tag variant="topic">{t}</Tag>)}
    </div>
  </div>

  <div class="pub-actions">
    {
      link && (
        <a class="pub-action" href={link} target="_blank" rel="noopener noreferrer">
          <Icon name={pub.doi ? 'external' : 'link'} size={15} />
          {pub.doi ? 'DOI' : 'Link'}
        </a>
      )
    }
    {
      freeLink && (
        <a class="pub-action" href={freeLink} target="_blank" rel="noopener noreferrer">
          <Icon name="download" size={15} /> PDF
        </a>
      )
    }
    <button class="pub-action js-copy-bibtex" data-bibtex={bibtex} aria-label={`Copy BibTeX for ${pub.title}`}>
      <Icon name="copy" size={15} />
      <span class="copy-label" aria-live="polite">BibTeX</span>
    </button>
  </div>
</article>

<style>
  .pub {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem 1.5rem;
    align-items: start;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-line);
  }
  .pub-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }
  .pub-title a {
    color: var(--color-ink);
    text-decoration: none;
  }
  .pub-title a:hover {
    color: var(--color-link);
    text-decoration: underline;
  }
  .pub-authors {
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
  .pub-authors strong {
    color: var(--color-ink);
    font-weight: 700;
  }
  .pub-meta {
    font-size: 0.9rem;
    color: var(--color-ink-faint);
    margin-top: 0.15rem;
  }
  .pub-meta cite {
    font-style: italic;
    color: var(--color-ink-soft);
  }
  .pub-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.65rem;
  }

  .pub-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.4rem;
    min-width: 6.5rem;
  }
  .pub-action {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    justify-content: flex-start;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 0.4rem 0.7rem;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }
  .pub-action:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
  }
  .pub-action.is-copied {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 40rem) {
    .pub {
      grid-template-columns: 1fr;
    }
    .pub-actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>

<script>
  // Copy-to-clipboard for BibTeX (one delegated handler for all items).
  function flash(btn: HTMLElement) {
    const label = btn.querySelector('.copy-label');
    const prev = label?.textContent ?? 'BibTeX';
    if (label) label.textContent = 'Copied!';
    btn.classList.add('is-copied');
    window.setTimeout(() => {
      if (label) label.textContent = prev;
      btn.classList.remove('is-copied');
    }, 1800);
  }

  async function copyText(text: string) {
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      // Fallback for non-secure contexts.
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.js-copy-bibtex') as HTMLElement | null;
    if (!btn) return;
    const bibtex = btn.getAttribute('data-bibtex');
    if (bibtex) {
      copyText(bibtex);
      flash(btn);
    }
  });
</script>
