# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in as needed. Everything has a safe default, so the
# site builds and runs with NO .env at all.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the deployed site. Used for canonical URLs, sitemap, RSS and
# absolute Open Graph image paths. Set this before going live.
SITE_URL="https://pksrivastava.netlify.app"

# Include the Keystatic editor (/keystatic) in a build. Defaults to off in
# production builds (a clean static site) and on in `npm run dev`.
#   ENABLE_KEYSTATIC="true"

# ── Keystatic GitHub storage (only for live editing in production) ───────────
# When set, the editor commits content edits to this repo on save. Requires a
# server adapter (Netlify/Vercel) and a GitHub App — see README §"Editing live".
#   PUBLIC_KEYSTATIC_GITHUB_REPO="owner/repo"
#   KEYSTATIC_GITHUB_CLIENT_ID="..."
#   KEYSTATIC_GITHUB_CLIENT_SECRET="..."
#   KEYSTATIC_SECRET="..."   # any long random string

# ── Publications ingestion (scripts/ingest-publications.mjs) ─────────────────
# Contact email sent to the Crossref "polite pool" for better rate limits.
CROSSREF_MAILTO="web_ccdc@iitp.ac.in"
